# --- Source selection ---
# api (default)  : Canvas REST API with a personal access token (below)
# canvas-cli     : token-free; reads Canvas via the canvas-cli companion (browser SSO)
#                  recommended for schools that disable Canvas tokens (e.g. some universities)
#                  "browser" is accepted as an alias for canvas-cli
# browser-bridge : advanced fallback; needs your own BROWSER_BRIDGE_PATH binary
CANVAS_SOURCE=api

# Required for the default "api" source. CANVAS_BASE_URL is also used by the
# canvas-cli source (passed through as --base-url).
CANVAS_BASE_URL=https://your-school.instructure.com
CANVAS_API_TOKEN=your-canvas-api-token

# Only for CANVAS_SOURCE=canvas-cli (token-free). Optional overrides:
# CANVAS_CLI_BIN=canvas-cli      # path/name of the canvas-cli binary (default: canvas-cli)
# CANVAS_PROFILE_NAME=default    # named canvas-cli login profile

# optional delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
DISCORD_WEBHOOK_URL=
# optional: where daily snapshots are written
CANVAS_DIGEST_SNAPSHOT_DIR=./snapshots
